{
  "name": "keksmeister",
  "version": "0.1.0",
  "description": "A modern, framework-agnostic cookie consent Web Component with Shadow DOM encapsulation. Built for GDPR/DSGVO compliance.",
  "type": "module",
  "main": "./dist/keksmeister.umd.cjs",
  "module": "./dist/keksmeister.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/keksmeister.js",
      "require": "./dist/keksmeister.umd.cjs"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./adapters/*": {
      "import": "./dist/adapters/*.js",
      "types": "./dist/adapters/*.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite serve demo",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cookie-consent",
    "gdpr",
    "dsgvo",
    "web-component",
    "custom-element",
    "shadow-dom",
    "privacy",
    "consent-management",
    "cookie-banner",
    "eprivacy"
  ],
  "author": "footage.one",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/footageone/keksmeister.git"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "@vitest/browser": "^4.1.1",
    "happy-dom": "^20.8.7"
  }
}
