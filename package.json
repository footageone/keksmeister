{
  "name": "keksmeister",
  "version": "0.1.2",
  "description": "A modern, framework-agnostic cookie consent Web Component with Shadow DOM encapsulation. Built for GDPR/DSGVO compliance.",
  "type": "module",
  "main": "./dist/keksmeister.umd.cjs",
  "module": "./dist/keksmeister.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/keksmeister.js",
      "require": "./dist/keksmeister.umd.cjs"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./adapters/*": {
      "import": "./dist/adapters/*.js",
      "types": "./dist/adapters/*.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./react": {
      "types": "./dist/wrappers/react.d.ts",
      "import": "./dist/wrappers/react.js"
    },
    "./angular": {
      "types": "./dist/wrappers/angular.d.ts",
      "import": "./dist/wrappers/angular.js"
    },
    "./vue": {
      "types": "./dist/wrappers/vue.d.ts",
      "import": "./dist/wrappers/vue.js"
    },
    "./i18n/*": {
      "import": "./dist/i18n/*.js",
      "types": "./dist/i18n/*.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite serve demo",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "cookie-consent",
    "gdpr",
    "dsgvo",
    "web-component",
    "custom-element",
    "shadow-dom",
    "privacy",
    "consent-management",
    "cookie-banner",
    "eprivacy"
  ],
  "author": "footage.one",
  "license": "MIT",
  "homepage": "https://footageone.github.io/keksmeister/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/footageone/keksmeister.git"
  },
  "bugs": {
    "url": "https://github.com/footageone/keksmeister/issues"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@vitest/browser": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "happy-dom": "^20.8.7",
    "husky": "^9.1.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
